import random
from ryu.base import app_manager
from ryu.controller import ofp_event
from ryu.controller.handler import CONFIG_DISPATCHER, MAIN_DISPATCHER, set_ev_cls
from ryu.ofproto import ofproto_v1_3
from ryu.lib.packet import packet, ethernet, ipv4, arp, icmp
from ryu.lib import hub

class MtdSwitch(app_manager.RyuApp):
    OFP_VERSIONS = [ofproto_v1_3.OFP_VERSION]

    def __init__(self, *args, **kwargs):
        super(MtdSwitch, self).__init__(*args, **kwargs)
        self.mac_to_port = {}
        
        # Mapeo estático de las direcciones MAC reales de la topología Mininet
        self.ip_to_mac = {
            '10.0.0.1': '00:00:00:00:00:01', 
            '10.0.0.2': '00:00:00:00:00:02', 
            '10.0.0.3': '00:00:00:00:00:03'
        }
        
        # Diccionarios de mutación dinámica
        self.real_to_virt = {'10.0.0.1': '10.0.0.1', '10.0.0.2': '10.0.0.2', '10.0.0.3': '10.0.0.3'}
        self.virt_to_real = {'10.0.0.1': '10.0.0.1', '10.0.0.2': '10.0.0.2', '10.0.0.3': '10.0.0.3'}
        
        # Hilo secundario para mutar IPs de forma periódica
        self.mutator_thread = hub.spawn(self._mutate_ips)

    def _mutate_ips(self):
        while True:
            hub.sleep(20)
            self.logger.info("--- [MTD] ¡MUTACIÓN DE DIRECCIONES IP ACTIVADA! ---")
            for real_ip in list(self.real_to_virt.keys()):
                # MODIFICADO: Se removió la excepción de 10.0.0.1 para que mute TODA la red
                nueva_virtual = f"10.0.0.{random.randint(100, 254)}"
                old_virt = self.real_to_virt[real_ip]
                
                if old_virt in self.virt_to_real:
                    del self.virt_to_real[old_virt]
                    
                self.real_to_virt[real_ip] = nueva_virtual
                self.virt_to_real[nueva_virtual] = real_ip
                self.logger.info(f"Host Real {real_ip} -> IP Virtual Activa: {nueva_virtual}")

    @set_ev_cls(ofp_event.EventOFPSwitchFeatures, CONFIG_DISPATCHER)
    def switch_features_handler(self, ev):
        datapath = ev.msg.datapath
        ofproto = datapath.ofproto
        parser = datapath.ofproto_parser
        match = parser.OFPMatch()
        actions = [parser.OFPActionOutput(ofproto.OFPP_CONTROLLER, ofproto.OFPCML_NO_BUFFER)]
        inst = [parser.OFPInstructionActions(ofproto.OFPIT_APPLY_ACTIONS, actions)]
        mod = parser.OFPFlowMod(datapath=datapath, priority=0, match=match, instructions=inst)
        datapath.send_msg(mod)

    @set_ev_cls(ofp_event.EventOFPPacketIn, MAIN_DISPATCHER)
    def _packet_in_handler(self, ev):
        msg = ev.msg
        datapath = msg.datapath
        ofproto = datapath.ofproto
        parser = datapath.ofproto_parser
        in_port = msg.match['in_port']
        pkt = packet.Packet(msg.data)
        eth = pkt.get_protocols(ethernet.ethernet)[0]
        dst = eth.dst
        src = eth.src
        dpid = datapath.id

        self.mac_to_port.setdefault(dpid, {})
        self.mac_to_port[dpid][src] = in_port

        # 1. MECANISMO PROXY ARP
        pkt_arp = pkt.get_protocol(arp.arp)
        if pkt_arp and pkt_arp.opcode == arp.ARP_REQUEST:
            dst_ip = pkt_arp.dst_ip
            if dst_ip in self.virt_to_real:
                real_ip = self.virt_to_real[dst_ip]
                mac_real = self.ip_to_mac[real_ip]
                
                arp_reply = packet.Packet()
                arp_reply.add_protocol(ethernet.ethernet(ethertype=eth.ethertype, dst=src, src=mac_real))
                arp_reply.add_protocol(arp.arp(opcode=arp.ARP_REPLY, src_mac=mac_real, src_ip=dst_ip, dst_mac=src, dst_ip=pkt_arp.src_ip))
                arp_reply.serialize()
                
                actions = [parser.OFPActionOutput(in_port)]
                out = parser.OFPPacketOut(datapath=datapath, buffer_id=ofproto.OFP_NO_BUFFER, in_port=ofproto.OFPP_CONTROLLER, actions=actions, data=arp_reply.data)
                datapath.send_msg(out)
                return

        # 2. MECANISMO PROXY ICMP (type_ con guion bajo, code sin guion bajo)
        pkt_ipv4 = pkt.get_protocol(ipv4.ipv4)
        pkt_icmp = pkt.get_protocol(icmp.icmp)
        if pkt_ipv4 and pkt_icmp and pkt_icmp.type == icmp.ICMP_ECHO_REQUEST:
            dst_ip = pkt_ipv4.dst
            if dst_ip in self.virt_to_real:
                icmp_reply = packet.Packet()
                icmp_reply.add_protocol(ethernet.ethernet(ethertype=eth.ethertype, dst=src, src=dst))
                icmp_reply.add_protocol(ipv4.ipv4(dst=pkt_ipv4.src, src=dst_ip, proto=pkt_ipv4.proto))
                icmp_reply.add_protocol(icmp.icmp(type_=icmp.ICMP_ECHO_REPLY, code=icmp.ICMP_ECHO_REPLY_CODE, data=pkt_icmp.data))
                icmp_reply.serialize()
                
                actions = [parser.OFPActionOutput(in_port)]
                out = parser.OFPPacketOut(datapath=datapath, buffer_id=ofproto.OFP_NO_BUFFER, in_port=ofproto.OFPP_CONTROLLER, actions=actions, data=icmp_reply.data)
                datapath.send_msg(out)
                return

        if dst in self.mac_to_port[dpid]:
            out_port = self.mac_to_port[dpid][dst]
        else:
            out_port = ofproto.OFPP_FLOOD

        actions = [parser.OFPActionOutput(out_port)]

        # 3. TRADUCCIÓN BIDIRECCIONAL IPV4 ESTÁNDAR GLOBAL
        if pkt_ipv4 and out_port != ofproto.OFPP_FLOOD:
            src_ip = pkt_ipv4.src
            dst_ip = pkt_ipv4.dst

            # Destino es una IP Virtual -> Traducir a IP Real para que el paquete sea entregado
            if dst_ip in self.virt_to_real:
                real_dst = self.virt_to_real[dst_ip]
                actions = [
                    parser.OFPActionSetField(ipv4_dst=real_dst),
                    parser.OFPActionOutput(out_port)
                ]
            # Origen es una IP Real -> Enmascarar con su IP Virtual activa actual
            # MODIFICADO: Se removió la restricción de '10.0.0.1' para incluirlo en la traducción
            elif src_ip in self.real_to_virt:
                virt_src = self.real_to_virt[src_ip]
                actions = [
                    parser.OFPActionSetField(ipv4_src=virt_src),
                    parser.OFPActionOutput(out_port)
                ]

        out = parser.OFPPacketOut(datapath=datapath, buffer_id=msg.buffer_id, in_port=in_port, actions=actions, data=msg.data if msg.buffer_id == ofproto.OFP_NO_BUFFER else None)
        datapath.send_msg(out)
